# App Configuration
APP_NAME=Forms Backend
APP_ENV=development
DEBUG=true

# MongoDB Configuration
# Local standalone example:
# MONGODB_URI=mongodb://localhost:27017/forms_db
# Shared RIDP infra example:
MONGODB_URI=mongodb://root:rootpassword@shared-mongo:27017/form_backend?authSource=admin

# Redis Configuration
# Local standalone example:
# REDIS_HOST=localhost
# Shared RIDP infra example:
REDIS_HOST=shared-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_DB=0
CELERY_RESULT_DB=1

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Sentry Configuration
SENTRY_DSN=

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
