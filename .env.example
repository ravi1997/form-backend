# ═══════════════════════════════════════════════════════════════════════════
# RIDP Form Platform — Environment Configuration Template
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Forms Backend
APP_ENV=development          # development | testing | production
DEBUG=true                   # Set false in production

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local standalone:
#   MONGODB_URI=mongodb://localhost:27017/forms_db
# Docker Compose shared infra:
MONGODB_URI=mongodb://root:rootpassword@shared-mongo:27017/form_backend?authSource=admin

# ── Redis ────────────────────────────────────────────────────────────────────
# Local standalone:
#   REDIS_HOST=localhost
# Docker Compose shared infra:
REDIS_HOST=shared-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_DB=0
CELERY_RESULT_DB=1

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcards in production).
# Examples:
#   Development:  http://localhost:3000,http://localhost:9600,http://localhost:8989
#   Production:   https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9600,http://localhost:8051,http://localhost:8989

# ── Security Headers ──────────────────────────────────────────────────────────
# HSTS (HTTP Strict Transport Security)
HSTS_MAX_AGE=31536000        # 1 year (seconds)
HSTS_PRELOAD=false           # Set true only when HSTS preload-list ready
HSTS_INCLUDE_SUBDOMAINS=true

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Global defaults. Per-endpoint overrides live in route decorators.
RATE_LIMIT_DEFAULT=2000 per hour,100 per minute

# ── File Uploads ─────────────────────────────────────────────────────────────
# Maximum request body size in bytes (default 16 MB)
MAX_CONTENT_LENGTH=16777216

# Upload storage backend: local | s3
UPLOAD_STORAGE=local
UPLOAD_DIR=/app/uploads

# AWS S3 (only if UPLOAD_STORAGE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Provider: local | ollama | openai
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (only if AI_PROVIDER=openai)
OPENAI_API_KEY=

# ── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=ridp_forms

# ── SMS / Comms ───────────────────────────────────────────────────────────────
SMS_API_KEY=
SMS_BEARER_TOKEN=
SMS_SENDER_ID=RIDPMS

# ── Monitoring & Observability ────────────────────────────────────────────────
# Sentry (leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# OpenTelemetry (OTLP gRPC endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=form-backend
OTEL_ENABLED=false           # Set true to enable distributed tracing

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=/app/logs

# ── eHospital / External APIs ─────────────────────────────────────────────────
EHOSPITAL_BASE_URL=
EHOSPITAL_API_KEY=
EHOSPITAL_TIMEOUT=10

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true/false to toggle platform-wide features
FEATURE_NLP_SEARCH=true
FEATURE_AI_SUMMARIZATION=true
FEATURE_ANOMALY_DETECTION=false
FEATURE_WEBHOOKS=true
FEATURE_WORKFLOWS=true

# ── Ports (for local docker-compose dev) ─────────────────────────────────────
PORT=8051
