# ==============================================================================
# form-backend .gitignore
# ==============================================================================
# This gitignore is for the forms management backend with AI capabilities
# Full-featured Flask application with Celery, Redis, PostgreSQL, and monitoring
# ==============================================================================

# ------------------------------------------------------------------------------
# Sensitive Files (NEVER COMMIT)
# ------------------------------------------------------------------------------
# Environment files with secrets
.env
.env.local
.env.*.local

# Private keys and certificates
*.key
*.pem
id_rsa
id_rsa.pub
credentials.json
*.p12
*.pfx

# Secrets directories
secrets/
.secrets/
private/

# Application-specific sensitive files
config/secrets.py
config/credentials.json

# ------------------------------------------------------------------------------
# Python Artifacts
# ------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.pytest_cache/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
# Virtual environment directories
venv/
env/
ENV/
.venv/
.virtualenv/
virtualenv/

# Virtualenv pip install
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# Celery Artifacts
# ------------------------------------------------------------------------------
# Celery beat schedule database
celerybeat-schedule
celerybeat.pid

# Celery worker state
*.pid

# ------------------------------------------------------------------------------
# Database Artifacts
# ------------------------------------------------------------------------------
# SQLite databases (if used for testing)
*.db
*.sqlite
*.sqlite3

# Database migrations (if using Alembic)
# Uncomment if you want to ignore migration scripts
# alembic/versions/*.py
# alembic/versions/*.pyc

# ------------------------------------------------------------------------------
# Docker Artifacts
# ------------------------------------------------------------------------------
# Docker build cache
.docker/

# Docker volumes and runtime data
*.log
logs/

# ------------------------------------------------------------------------------
# Logs Directory (Runtime Generated)
# ------------------------------------------------------------------------------
# All log files
logs/
*.log
logs/*.log

# Specific log files mentioned in the project
logs/access.log
logs/application.log
logs/audit.log
logs/error.log
logs/performance.log

# ------------------------------------------------------------------------------
# IDE and Editor Files
# ------------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*.swn
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.nfs*

# ------------------------------------------------------------------------------
# Testing and Quality Assurance
# ------------------------------------------------------------------------------
# Test artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# Linting artifacts
.flake8_cache/
.pyre/
.mypy_cache/

# ------------------------------------------------------------------------------
# Application-Specific Generated Files
# ------------------------------------------------------------------------------
# API documentation exports
openapi.json
swagger.json
api-docs/

# Generated schema files
schemas/generated/

# Temporary data
tmp/
temp/
*.tmp
*.temp

# ------------------------------------------------------------------------------
# Playwright Artifacts
# ------------------------------------------------------------------------------
tests-playwright/node_modules/
tests-playwright/test-results/
tests-playwright/playwright-report/

# Cache directories
.cache/
__pycache__/

# ------------------------------------------------------------------------------
# Redis and Cache Artifacts
# ------------------------------------------------------------------------------
# Redis dump files (if using local Redis for testing)
dump.rdb

# ------------------------------------------------------------------------------
# Monitoring and Observability
# ------------------------------------------------------------------------------
# Sentry DSN files (if committed by mistake)
.sentryclirc

# OpenTelemetry trace files
*.trace

# ------------------------------------------------------------------------------
# Documentation Artifacts
# ------------------------------------------------------------------------------
# Generated documentation
docs/_build/
docs/.doctrees/
docs/*.pdf

# Sphinx build
docs/build/

# ------------------------------------------------------------------------------
# Build and Distribution
# ------------------------------------------------------------------------------
# Build outputs
bin/
obj/
out/
target/

# Distribution files
dist/
build/
*.egg
*.egg-info/

# ------------------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------------------
# Backup files
*.bak
*.backup

# Local configuration overrides
*.local
local.*

# Debug files
debug.log
*.debug

# Session files
*.session
*.session-journal
