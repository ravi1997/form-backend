# RIDP environment template for form-backend
# Render with: python3 ../../platform/cli.py scaffold --name form-backend --port 8051
# Or manually: cp .env.j2 .env  (then fill in the {{ ... }} placeholders)

# ── RIDP Platform ─────────────────────────────────────────────────────────
APP_NAME=form-backend
PORT=8051
APP_ENV=production
DEBUG=false

# ── RIDP Shared: MongoDB ──────────────────────────────────────────────────
# Authenticated URI for shared-infra MongoDB
MONGODB_URI=mongodb://root:rootpassword@shared-mongo:27017/forms_db?authSource=admin

# ── RIDP Shared: Redis ────────────────────────────────────────────────────
REDIS_HOST=shared-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://shared-redis:6379/0

# ── Celery (uses shared Redis as broker) ──────────────────────────────────
CELERY_BROKER_DB=0
CELERY_RESULT_DB=1
CELERY_BROKER_URL=redis://shared-redis:6379/0
CELERY_RESULT_BACKEND=redis://shared-redis:6379/1

# ── Elasticsearch (standalone container: forms_elasticsearch) ─────────────
ELASTICSEARCH_URL=http://forms_elasticsearch:9200

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY={{ flask_secret_key }}
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Sentry (optional, leave blank to disable) ─────────────────────────────
SENTRY_DSN=
